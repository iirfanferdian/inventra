// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"

}

// 1. Model User (Kompatibel dengan NextAuth)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String // Hashed password
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relasi
  items         Item[]
  transactions  Transaction[]
  categories    Category[]
}

// 2. Model Kategori (Untuk pengelompokan barang)
model Category {
  id        String   @id @default(cuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     Item[]

  @@unique([name, userId]) // User tidak boleh punya kategori dengan nama yang sama
}

// 3. Model Item (Inti Inventori)
model Item {
  id           String    @id @default(cuid())
  sku          String    @unique // Kode unik barang (Stock Keeping Unit)
  name         String
  description  String?
  price        Decimal   @db.Decimal(12, 2) // Contoh: 1.000.000,00
  currentStock Int       @default(0)
  minStock     Int       @default(5) // Untuk alert "Low Stock"
  
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  transactions Transaction[]
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([sku])
}

// 4. Model Transaction (Log Keluar Masuk)
enum TransactionType {
  IN   // Barang masuk / restock
  OUT  // Barang keluar / terjual
}

model Transaction {
  id              String          @id @default(cuid())
  type            TransactionType
  quantity        Int
  priceAtTransaction Decimal      @db.Decimal(12, 2) // Harga saat transaksi terjadi (bisa berubah dari harga master)
  note            String?
  
  itemId          String
  item            Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime        @default(now())

  @@index([itemId])
  @@index([userId])
  @@index([createdAt])
}
