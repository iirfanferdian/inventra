// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"

}


model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
  @@map("accounts")
}
 
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@unique([identifier, token])
  @@map("verification_tokens")
}

// 1. Model User (Kompatibel dengan NextAuth)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  role          String @default("user")
  accounts      Account[]
  sessions      Session[]
  currency      String    @default("IDR")
  bio           String    @default("")
 
  @@map("users")
  // Relasi
  items         Item[]
  transactions  Transaction[]
  categories    Category[]
}

// 2. Model Kategori (Untuk pengelompokan barang)
model Category {
  id        String   @id @default(cuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     Item[]

  @@unique([name, userId]) // User tidak boleh punya kategori dengan nama yang sama
}

// 3. Model Item (Inti Inventori)
model Item {
  id           String    @id @default(cuid())
  sku          String    @unique // Kode unik barang (Stock Keeping Unit)
  name         String
  description  String?
  price        Decimal   @db.Decimal(12, 2) // Contoh: 1.000.000,00
  currentStock Int       @default(0)
  minStock     Int       @default(5) // Untuk alert "Low Stock"
  
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  transactions Transaction[]
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([sku])
}

// 4. Model Transaction (Log Keluar Masuk)
enum TransactionType {
  IN   // Barang masuk / restock
  OUT  // Barang keluar / terjual
}

model Transaction {
  id              String          @id @default(cuid())
  type            TransactionType
  quantity        Int
  priceAtTransaction Decimal      @db.Decimal(12, 2) // Harga saat transaksi terjadi (bisa berubah dari harga master)
  note            String?
  
  itemId          String
  item            Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime        @default(now())

  @@index([itemId])
  @@index([userId])
  @@index([createdAt])
}
